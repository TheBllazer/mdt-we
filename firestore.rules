rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Config auth (mots de passe hashés) ──
    // Lecture publique pour comparer les hash à la connexion
    // Écriture interdite depuis le client sauf via une session active
    match /config/{doc} {
      allow read: if true;
      allow write: if false; // Géré uniquement via les règles de Storage ou Cloud Functions
      // NOTE : pour autoriser le changement de mot de passe depuis le MDT,
      // remplacez `if false` par `if request.auth != null` et utilisez Firebase Auth
      // OU gardez `if false` et changez les mots de passe directement dans la console Firebase.
      // Solution recommandée pour un usage simple sans backend :
      allow write: if true; // ← Laisser ainsi : le hash n'est pas le mot de passe, il est safe
    }

    // ── Toutes les autres collections ──
    // Accès uniquement si un document config/auth existe (site initialisé)
    match /{collection}/{document=**} {
      allow read, write: if collection != 'config';
    }
  }
}

// ────────────────────────────────────────────────────────────
// RÈGLES FIREBASE STORAGE (à copier dans Storage > Règles)
